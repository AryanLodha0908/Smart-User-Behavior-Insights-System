# MongoDB Atlas Connection String
# Format: mongodb+srv://username:password@cluster-url/database?retryWrites=true&w=majority
# Get this from: MongoDB Atlas → Connect → Connection String
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/behavior_insights?retryWrites=true&w=majority

# Server Port
PORT=5000

# ML Service URL (for local development)
ML_SERVICE_URL=http://localhost:5001

# Environment
NODE_ENV=development
